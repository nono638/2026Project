      "Bash(py *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(pytest *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cd *)",
      "Bash(cd *&&*)",
      "Bash(dir *)",
      "Bash(dir)",
      "Bash(mkdir *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sort *)",
      "Bash(tree *)",
      "Bash(type *)",
      "Bash(copy *)",
      "Bash(move *)",
      "Bash(set *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(dotnet *)",
      "Bash(java *)",
