      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git checkout -- .)",
      "Bash(reg *)",
      "Bash(regedit*)",
      "Bash(taskkill *)",
      "Bash(shutdown *)",
      "Bash(mklink *)",
      "Bash(net user*)",
      "Bash(net localgroup*)",
      "Bash(netsh *)",
      "Bash(schtasks *)",
      "Bash(sc config*)",
      "Bash(sc stop*)",
      "Bash(sc delete*)",
      "Bash(bcdedit*)",
      "Bash(diskpart*)",
      "Bash(powershell*Remove-Item*-Recurse*)",
      "Bash(powershell*rm -r*)",
      "Bash(powershell*Format-Volume*)",
      "Bash(powershell*Clear-Disk*)",
      "Bash(powershell*Set-ExecutionPolicy*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(Invoke-WebRequest*)",
      "Bash(Invoke-RestMethod*)",
      "Bash(powershell*Invoke-WebRequest*)",
      "Bash(powershell*Invoke-RestMethod*)",
      "Bash(powershell*curl*)",
      "Bash(powershell*wget*)",
