      "Bash(bash -c *)",
      "Bash(*| head *)",
      "Bash(*| tail *)",
      "Bash(*| wc *)",
      "Bash(*| grep *)",
      "Bash(*| sort *)",
      "Bash(*| sort)",
      "Bash(.venv/*)",
      "Bash(source *)",
      "Bash(. *)",
      "Bash(chmod *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *.py)",
      "Bash(rm *.js)",
      "Bash(rm *.ts)",
      "Bash(rm *.txt)",
      "Bash(rm *.json)",
      "Bash(rm *.csv)",
      "Bash(rm *.log)"
