      "Bash(*| wget *)",
      "Bash(gh *)",
      "Bash(start *)",
      "Bash(powershell *)",
      "Bash(pwsh *)",
      "Bash(*powershell*)",
      "Bash(*pwsh*)",
      "WebFetch",
      "WebSearch",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",
      "Read(**/credentials*)",
      "Read(**/*secret*)",
      "Read(**/*password*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|Glob|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/hooks/directory_guard.py\""
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude/hooks/no_ask_human.py\""
          }
        ]
      }
    ]
  }
}
